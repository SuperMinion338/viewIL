generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int                   @id @default(autoincrement())
  name              String
  email             String                @unique
  password          String
  plan              String                @default("free")
  avatarUrl         String?
  instagramUrl      String?
  tiktokUrl         String?
  scriptsThisMonth  Int                   @default(0)
  scriptsMonthKey   String?
  referralCode      String?               @unique
  createdAt         DateTime              @default(now())
  scripts           SavedScript[]
  hooks             SavedHook[]
  income            Income[]
  calendarEvents    CalendarEvent[]
  analyses          PerformanceAnalysis[]
  referralsSent     Referral[]            @relation("ReferralsSent")
  referralsReceived Referral[]            @relation("ReferralsReceived")
  contentProjects   ContentProject[]
}

model Referral {
  id         Int      @id @default(autoincrement())
  referrerId Int
  referredId Int
  createdAt  DateTime @default(now())
  referrer   User     @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referred   User     @relation("ReferralsReceived", fields: [referredId], references: [id], onDelete: Cascade)
}

model PerformanceAnalysis {
  id           Int      @id @default(autoincrement())
  userId       Int
  title        String
  platform     String
  views        Int      @default(0)
  likes        Int      @default(0)
  comments     Int      @default(0)
  shares       Int      @default(0)
  saves        Int      @default(0)
  reach        Int      @default(0)
  groqAnalysis String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Income {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  source    String
  amount    Float
  platform  String
  date      String
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedScript {
  id        Int      @id @default(autoincrement())
  userId    Int
  idea      String
  tone      String?
  hook      String?
  body      String?
  cta       String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedHook {
  id        Int      @id @default(autoincrement())
  userId    Int
  topic     String
  platform  String?
  hooks     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      String
  title     String
  platform  String?
  notes     String?
  color     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContentProject {
  id        Int       @id @default(autoincrement())
  userId    Int
  title     String
  platform  String
  stage     String    @default("idea")
  priority  String    @default("medium")
  dueDate   DateTime?
  notes     String?
  checklist Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
